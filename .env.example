# =============================================================================
# CareCircle — .env.example
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git. It is in .gitignore.
#
#   cp .env.example .env
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=carecircle_db
DB_USERNAME=carecircle_user
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USERNAME=carecircle
RABBITMQ_PASSWORD=change_me_rabbit_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_EXPIRY_MS=900000        # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
